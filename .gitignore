# Python
__pycache__/
*.pyc
*.pyo
*.pyd

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Ansible
*.retry

# Vault (실제 비밀은 커밋하지 않음)
# vault/*.yml 은 ansible-vault 로 암호화된 상태로만 커밋
.vault_pass
.vault_pass.*
*.vault_password
vault/*.unencrypted.yml
vault/redfish/*.unencrypted.yml

# Lab 자격증명 (로컬 전용 — repo private 전환 전까지 commit 금지)
# 2026-04-29 cycle-015 — 사용자가 public 작업 종료 후 private 전환 예정
vault/.lab-credentials.yml
vault/.lab-credentials.*.yml
inventory/lab/
inventory/lab/**

# Supplemental test inventory (local credentials — never tracked)
tests/inventory/local/*
!tests/inventory/local/.gitkeep

# Conditional review targets and local credentials — never tracked
tests/scripts/local/*
!tests/scripts/local/.gitkeep

# Reference 수집 — 자격 / 임시 raw / 진행 로그는 commit 안 함
tests/reference/local/*
!tests/reference/local/.gitkeep
tests/reference/.cache/
tests/reference/**/.crawl_inflight/

# AI scheduled wakeup runtime state
.claude/scheduled_tasks.lock

# AI 하네스 — 로컬 캐시 / 개인 설정 (commit 금지)
.claude/.cache/
.claude/settings.local.json

# Incoming-review 자동 보고서 (각 머지마다 생성, 정리 후 후속 PR)
docs/ai/incoming-review/*-*.md
!docs/ai/incoming-review/.gitkeep
.cache/

# Jenkins 작업 잔재 (로컬 디버깅 / probe 결과 — commit 금지)
# cycle-018 (2026-05-01) 추가
.jenkins_*.log
.jenkins_builds.json
.console-*.txt
_console_*.log
_jenkins.cookie
_buildnum.txt
_job.json
_lb.json
b[0-9].log
b[0-9][0-9].log

# vault 복호화 헬퍼 (개인 도구 — 하드코딩 자격 leak 차단)
