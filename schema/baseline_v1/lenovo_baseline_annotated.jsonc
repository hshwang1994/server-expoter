          "mtu":          null,
          "speed_mbps":   null,
          "link_status":  "linkdown",
          "is_primary":   false,
          "addresses":    []
        }
        // ... NIC2, NIC3 등 생략. 이름이 "NIC1/NIC2/..." 라서 사람이 읽기 좋음.
        // (Dell: "NIC.Slot.7-1-1" 같은 BMC 내부 토큰)
      ]
    },

    // === 하드웨어 ===
    "hardware": {
      "vendor": "Lenovo",                                       // 또는 "IBM" (구형) — vendor_aliases.yml 에서 둘 다 lenovo 로 정규화
      "model":  "...",                                           // 예: "ThinkSystem SR650 V2"
      // "oem": Lenovo 는 거의 비어있음 (표준 영역에 충실)
      // ... 나머지 dell 과 동일 구조
    },

    // === 펌웨어 — Lenovo 의 component 형식 ===
    "firmware": [
      {
        "id":         "...",
        "name":       "BMC Firmware",
        "version":    "5.70",
        "updateable": true,
        "component":  "BMC-AFBT-10"                              // ← Lenovo 형식 (Dell 은 숫자만, HPE 는 숫자/UUID)
      }
      // ... 펌웨어 목록 다수 생략
    ],

    // 나머지 (storage / cpu / memory / power / system) 는 dell 과 동일 구조라 생략
    "memory":  { /* ... slots[] 풍부 */ },
    "storage": { /* ... physical_disks / logical_volumes / controllers */ },
    "cpu":     { /* ... */ },
    "power":   { /* ... PSU + power_control */ },
