// ============================================================
// Lenovo SR650 V2 (XCC) — Redfish 채널 수집 결과
// ============================================================
// 원본은 같은 폴더의 lenovo_baseline.json.
//
// dell_baseline_annotated.jsonc 와 같은 envelope 구조라
// 본 파일은 **Lenovo 만의 차이점** 만 짧게 주석.
//
// Lenovo 의 특징:
//   - bmc.name = "XCC" (XClarity Controller)
//   - bmc.firmware_version 표기에 빌드코드 + 버전 + 빌드일 ("AFBT58B 5.70 2025-08-11")
//   - hostname 으로 BMC 가 자기 이름 보고 ("XCC-7Z73-J30AF7LC" 형식)
//   - NIC ID 가 의미 있는 이름 ("ToManager", "NIC1", "NIC2" — Dell 은 "NIC.Slot.7-1-1")
//   - oem 영역이 거의 비어있음 (Lenovo 는 표준 Redfish 영역에 충실)
//   - bmc.health 가 null 인 케이스 있음 (XCC 펌웨어 버전에 따라 미보고)

{
  "target_type":      "redfish",
  "collection_method":"redfish_api",
  "ip":               "10.50.11.232",
  "hostname":         "XCC-7Z73-J30AF7LC",   // ← Lenovo 특징! BMC 가 자기 이름 보고
                                              //   "XCC-<machine type>-<serial>" 형식
  "vendor":           "lenovo",                // "Lenovo" 또는 "IBM" → "lenovo" 정규화

  "status":           "success",
