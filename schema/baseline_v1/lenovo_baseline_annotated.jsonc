    "bmc": {
      "name":             "XCC",                              // ← Lenovo XClarity Controller 약자
      "firmware_version": "AFBT58B 5.70 2025-08-11",          // 빌드코드 + 버전 + 빌드일
                                                               //   AFBT58B = 펌웨어 빌드 ID
                                                               //   5.70    = 사용자 보는 버전
                                                               //   날짜    = 빌드일
      "model":            "Lenovo XClarity Controller",
      "manager_type":     "BMC",
      "health":           null,                                // XCC 일부 펌웨어에서 health 미보고
      "ip":               "10.50.11.232",
      "oem":              {}                                   // Lenovo 는 표준 영역 충실, OEM 거의 안 씀
    },

    // === 네트워크 — Lenovo 의 의미 있는 NIC ID ===
    "network": {
      "dns_servers":      [],
      "interfaces": [
        {
          "id":           "ToManager",                         // ← BMC 내부 인터페이스 (관리망)
          "name":         "Host Ethernet Interface",
          "kind":         "server_nic",
          "mac":          "3a:68:dd:89:59:4f",
          "mtu":          null,
          "speed_mbps":   100,
          "link_status":  "linkup",
          "is_primary":   false,
