    "failure_stage": null, "failure_reason": null,
    "details": {
      "channel":           "redfish",
      "adapter_candidate": "redfish_lenovo_xcc",
      "checked_ports":     [443],
      "selected_port":     443,
      "redfish_version":   "1.15.0",            // Lenovo XCC 의 Redfish 스펙
      "product":           null,                 // Lenovo 는 product 필드 안 줌 (manufacturer 만)
      "systems_uri":       "/redfish/v1/Systems"
