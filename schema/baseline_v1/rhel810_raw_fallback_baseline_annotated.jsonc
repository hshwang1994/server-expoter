    "details": {
      "channel":           "os",
      "adapter_candidate": "os_linux_rhel",      // RHEL 전용 adapter 매칭
      "detected_os":       "linux",
      "selected_port":     22,
      "checked_ports":     [22],

      // ↓ ↓ ↓ raw fallback 모드의 핵심 단서 3개 ↓ ↓ ↓
      "gather_mode":       "raw_only",            // python_ok / raw_only / raw_forced
                                                  // raw_only = Python 미설치 또는 3.8 이하라 자동 fallback
      "python_version":    "3.6.8",               // preflight 가 감지한 Python 버전
      "python_path":       "/usr/bin/python3"
    }
  },

  "meta": {
    "started_at":      "2026-04-29T05:30:01.123456Z",
    "finished_at":     "2026-04-29T05:30:09.654321Z",
    "duration_ms":     8500,                       // raw 모드는 setup 안 돌려서 보통 더 빠름
    "adapter_id":      "os_linux_rhel",
    "adapter_version": "1.0.0",
    "ansible_version": "2.20.3"
  },

  "correlation": {
    "serial_number": "VMware-42 0c 9d 1e 5a 7b 90 31-c4 8d 7e f0 22 19 33 ab",
    "system_uuid":   "1e9d0c42-7b5a-3190-c48d-7ef0221933ab",
