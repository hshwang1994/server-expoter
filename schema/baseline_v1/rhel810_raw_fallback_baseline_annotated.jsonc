// ============================================================
// RHEL 8.10 (VM, Python 3.6) — OS 채널 raw fallback 모드 결과
// ============================================================
// 원본은 같은 폴더의 rhel810_raw_fallback_baseline.json.
//
// 이 baseline 의 의의:
//   RHEL 8.10 은 Python 3.6 만 갖고 있어서 Ansible setup 모듈이 동작 안 한다.
//   server-exporter 는 이런 환경을 자동으로 감지해서 "raw 모드" 로 전환한다.
//   raw 모드 = remote 에서는 `raw` 모듈만 쓰고, 컨트롤러 쪽에서 Jinja2 로 파싱.
//
// ubuntu_baseline_annotated.jsonc 와 비교:
//   - diagnosis.details 에 gather_mode = "raw_only" 가 박힘 (← 핵심 차이)
//   - python_version = "3.6.8" 이 함께 기록됨
//   - 결과 envelope 모양은 100% 동일 (호환성 보장)
//   - memory.installed_mb 가 dmidecode 기반으로 채워짐 (Python 모드보다 정밀)

{
  "target_type":      "os",
  "collection_method":"agent",
  "ip":               "10.100.64.161",
  "hostname":         "rhel810-test01.gooddi.lab",
  "vendor":           null,

  "status":           "success",
  "sections": {
    "system":   "success",
    "hardware": "not_supported",
    "bmc":      "not_supported",
    "cpu":      "success",
    "memory":   "success",
    "storage":  "success",
    "network":  "success",
    "firmware": "not_supported",
    "users":    "success",
    "power":    "not_supported"
