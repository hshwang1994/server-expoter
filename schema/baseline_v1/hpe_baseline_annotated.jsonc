    "power":    "success"
  },

  "diagnosis": {
    "reachable": true, "port_open": true,
    "protocol_supported": true, "auth_success": true,
    "failure_stage": null, "failure_reason": null,
    "details": {
      "channel":           "redfish",
      "adapter_candidate": "redfish_hpe_ilo5",   // HPE iLO 5 adapter 매칭
      "checked_ports":     [443],
      "selected_port":     443,
      "redfish_version":   "1.20.0",              // HPE iLO 6 의 Redfish 스펙 (Dell iDRAC9 는 1.6.0)
      "product":           "ProLiant DL380 Gen11",
      "systems_uri":       "/redfish/v1/Systems/"
    }
  },

  "meta": {
    "started_at":      "2026-04-01T04:35:36.211203Z",
