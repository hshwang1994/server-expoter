    "duration_ms":     106000,
    "adapter_id":      "redfish_hpe_ilo5",
    "adapter_version": "1.0.0",
    "ansible_version": "2.20.3"
  },

  "correlation": {
    "serial_number": "SGH504HNZK",                     // HPE 시리얼 형식 (10자)
    "system_uuid":   "35323550-3433-4753-4835-3034484E5A4B",
    "bmc_ip":        "10.50.11.231",
    "host_ip":       "10.50.11.231"
  },

  "errors": [],

  "data": {

    // === BMC — HPE 특징 ===
    "bmc": {
      "name":             "iLO",                     // ← Dell=iDRAC, Lenovo=XCC, Cisco=CIMC, HPE=iLO
      "firmware_version": "iLO 6 v1.73",             // 세대명 + 버전 묶어서 보고
      "model":            "iLO 6",
      "manager_type":     "BMC",
      "health":           "OK",
      "ip":               "10.50.11.231",
      "oem": {
        "ilo_version":    null                        // HPE OEM 자체 키. 일부 펌웨어에서 채움.
      }
    },

    // === 네트워크 — HPE 의 link_status "none" 패턴 ===
    "network": {
      "dns_servers":      [],
      "default_gateways": [],
      "interfaces": [
        {
          "id":           "9",                        // HPE 는 NIC ID 가 단순 정수 (Dell 은 "NIC.Slot.7-1-1")
          "name":         "9",
          "kind":         "server_nic",
          "mac":          "8c:84:74:e9:be:84",
          "mtu":          null,
          "speed_mbps":   null,
          "link_status":  "none",                     // ← HPE 특이점!
                                                       // iLO 가 NIC 상태 정보를 안 줄 때 "none".
                                                       // (linkdown 과 다름. 정보 없음 = 미보고)
          "is_primary":   false,
          "addresses":    []
        }
        // ... 다른 NIC 도 비슷한 패턴 (link_status="none" 다수)
      ],
      "summary": { "groups": [/* ... */] }
    },

    // === 메모리 — Dell 과 거의 동일. DIMM slots 풍부.
    "memory": { /* ... 생략. 구조는 dell 과 동일. total_basis = physical_installed */ },

    // === 하드웨어 ===
    "hardware": {
      "vendor":       "HPE",                          // BMC 가 보고한 원본 (HPE 는 짧게 보고)
      "model":        "ProLiant DL380 Gen11",
      // "sku":       HPE 는 파트 번호 (Dell=서비스 태그). 이 케이스는 null 일 수도.
      // "oem":       Dell 처럼 chassis_service_tag 같은 풍부한 키 없음. HPE 는 표준 필드를 채움.
      // ... 이하 dell 과 동일 구조
    },

    // === 스토리지 — HPE Gen11+ 의 차이 ===
    // HPE Gen11 부터는 controllers[].drives 가 비어있고
    // StorageControllers 링크를 따로 호출해야 한다.
    // server-exporter 는 이를 자동 처리.
    "storage": { /* ... 구조는 dell 과 동일. logical_volumes / physical_disks / controllers */ },

    // === 펌웨어 — HPE 의 component 형식 ===
    "firmware": [
      {
        "id":         "...",
        "name":       "iLO 6",
        "version":    "1.73",
        "updateable": true,
        "component":  "..."                            // HPE 는 숫자 또는 UUID (Dell 은 숫자만)
      }
      // ... 펌웨어 목록 다수 생략
    ],

    "system":   { /* fqdn 만 BMC 가 보고. 나머지 null */ },
    "users":    [],   // Redfish 채널 미지원
    "power":    { /* PSU + power_control. 구조는 dell 과 동일 */ },
    "cpu":      { /* 구조는 dell 과 동일 */ }
  },

  "schema_version": "1"
