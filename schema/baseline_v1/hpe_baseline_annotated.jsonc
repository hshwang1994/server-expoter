// ============================================================
// HPE ProLiant DL380 Gen11 (iLO 6) — Redfish 채널 수집 결과
// ============================================================
// 원본은 같은 폴더의 hpe_baseline.json.
//
// 본 파일은 Dell baseline (dell_baseline_annotated.jsonc) 과 같은 envelope 구조라
// 중복 설명은 생략하고, **HPE 만의 차이점** 위주로 주석을 단다.
// 처음 보는 분은 dell_baseline_annotated.jsonc 를 먼저 읽고 오기를 권장.
//
// HPE 의 특징:
//   - bmc.name = "iLO" (Dell=iDRAC, Lenovo=XCC, Cisco=CIMC)
//   - bmc.firmware_version 표기에 "iLO 6 v1.73" 처럼 세대 + 버전 묶음
//   - network.interfaces[].link_status 가 "none" 인 케이스 다수 (iLO 가 NIC 상태 미보고)
//   - storage 컨트롤러 응답이 Dell 보다 단순 (StorageControllers 링크 별도 호출 — Gen11+ 차이)
//   - oem 영역이 Dell 보다 작음 (HPE 는 표준 필드를 더 많이 채워줌)

{
  "target_type":      "redfish",
  "collection_method":"redfish_api",
  "ip":               "10.50.11.231",
  "hostname":         "10.50.11.231",       // BMC 가 fqdn 안 줘서 ip fallback (정상)
  "vendor":           "hpe",                 // "Hewlett Packard Enterprise" → "hpe" 정규화

  "status":           "success",
  "sections": {
    "system":   "not_supported",
    "hardware": "success",
    "bmc":      "success",
    "cpu":      "success",
    "memory":   "success",
